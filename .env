# Application Configuration
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/capacitar-t

# Database Configuration
DB_HOST=localhost
DB_NAME=capacitar_t_mx
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Security Configuration
SESSION_TIMEOUT=7200
PASSWORD_MIN_LENGTH=8

# Email Configuration (for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=info@capacitar-t.com.mx
FROM_NAME=Capacitar-T México

# API Configuration
API_RATE_LIMIT=100

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=assets/uploads/

# Medical Configuration
DEFAULT_COURSE_DURATION=8
MAX_PARTICIPANTS_DEFAULT=20
CERTIFICATION_VALIDITY_YEARS=2

# Feature Flags
AHA_CERTIFIED=true
ERC_CERTIFIED=true
ILCOR_CERTIFIED=true

# Timezone
TIMEZONE=America/Mexico_City